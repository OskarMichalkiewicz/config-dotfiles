#!/usr/bin/env zsh

# Load local environment variables
if [ -f "$DOTFILES/.env" ]; then
    source "$DOTFILES/.env"
fi

export STOW_FOLDERS="alacritty,bin,nvim,tmux,zsh,starship,aerospace,sketchybar,jankyborders,gitconfig,opencode"
export DOTFILES=$HOME/dotfiles

addToPath() {
    if [[ "$PATH" != *"$1"* ]]; then
        export PATH=$PATH:$1
    fi
}

addToPathFront() {
    if [[ "$PATH" != *"$1"* ]]; then
        export PATH=$1:$PATH
    fi
}
