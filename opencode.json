{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": ["npx", "@wordbricks/fetch-mcp@latest"],
      "enabled": true
    },
    "context-mode": {
      "type": "local",
      "command": ["context-mode"],
      "enabled": true
    }
  },
  "instructions": [
    "/Users/admin/.config/opencode/rules/*.md"
  ]
}
